# FlashPad — Mac App Store pipeline.
#
# Required env (see RUNBOOK.md):
#   ASC_KEY_ID       App Store Connect API key id
#   ASC_ISSUER_ID    App Store Connect API issuer id
#   ASC_KEY_PATH     path to the AuthKey_XXXX.p8 file
#   DEVELOPMENT_TEAM 10-char Apple Developer Team ID
#
# Lanes:
#   fastlane mac bootstrap   # once: register the App ID + create the app record
#   fastlane mac release     # build, sign, upload to App Store Connect
#   fastlane mac submit      # release + submit for review

default_platform(:mac)

def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: ENV.fetch("ASC_KEY_PATH"),
    in_house: false,
  )
end

platform :mac do
  desc "One-time: register the App ID and create the App Store Connect record."
  lane :bootstrap do
    produce(
      api_key: asc_api_key,
      app_identifier: "tech.aldo.flashpad",
      app_name: "FlashPad",
      platforms: ["osx"],
      mac: true,
    )
  end

  desc "Build + sign + upload to App Store Connect."
  lane :release do
    do_upload(submit: false)
  end

  desc "Build + sign + upload + submit for review."
  lane :submit do
    do_upload(submit: true)
  end

  private_lane :do_upload do |options|
    key = asc_api_key
    team = ENV.fetch("DEVELOPMENT_TEAM")

    sh("cd .. && xcodegen generate")

    build_mac_app(
      project: "FlashPad.xcodeproj",
      scheme: "FlashPad",
      configuration: "Release",
      export_method: "app-store",
      export_team_id: team,
      # Let Xcode create/refresh the distribution cert + Mac App Store profile.
      xcargs: "-allowProvisioningUpdates DEVELOPMENT_TEAM=#{team} CODE_SIGN_STYLE=Automatic",
      output_directory: "build",
      output_name: "FlashPad",
    )

    upload_to_app_store(
      api_key: key,
      pkg: "build/FlashPad.pkg",
      submit_for_review: options[:submit],
      automatic_release: false,
      force: true,                       # skip the HTML preview prompt
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      skip_screenshots: false,
      skip_metadata: false,
    )
  end
end
